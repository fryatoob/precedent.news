{
  "version": 2,
  "functions": {
    "api/publish.js": {
      "memory": 256,
      "maxDuration": 15
    },
    "api/article.js": {
      "memory": 256,
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Authorization, Content-Type" }
      ]
    }
  ],
 "rewrites": [
    { "source": "/article/:id", "destination": "/pages/article.html" }
  ]
}
